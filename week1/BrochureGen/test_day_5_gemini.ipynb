import unittest
from unittest.mock import patch, MagicMock
from week1.BrochureGen.day_5_gemini import get_all_details, Website, get_links

# filepath: week1/BrochureGen/test_day_5_gemini.ipynb

class TestGetAllDetails(unittest.TestCase):
    @patch("week1.BrochureGen.day_5_gemini.get_links")
    @patch("week1.BrochureGen.day_5_gemini.Website")
    def test_get_all_details(self, MockWebsite, mock_get_links):
        # Mock Website.get_contents
        mock_website_instance = MagicMock()
        mock_website_instance.get_contents.return_value = "Mocked landing page content"
        MockWebsite.return_value = mock_website_instance

        # Mock get_links
        mock_get_links.return_value = {
            "links": [
                {"type": "about page", "url": "https://example.com/about"},
                {"type": "careers page", "url": "https://example.com/careers"}
            ]
        }

        # Mock Website for links
        mock_about_page = MagicMock()
        mock_about_page.get_contents.return_value = "Mocked about page content"
        mock_careers_page = MagicMock()
        mock_careers_page.get_contents.return_value = "Mocked careers page content"
        MockWebsite.side_effect = [mock_website_instance, mock_about_page, mock_careers_page]

        # Call the function
        result = get_all_details()

        # Assertions
        self.assertIn("Landing page:\nMocked landing page content", result)
        self.assertIn("about page\nMocked about page content", result)
        self.assertIn("careers page\nMocked careers page content", result)

if __name__ == "__main__":
    unittest.main()